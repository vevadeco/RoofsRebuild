# ── Required ──────────────────────────────────────────────────────────────────

# Neon PostgreSQL connection string
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# JWT secret — generate with: openssl rand -base64 32
JWT_SECRET=your-secret-here

# Admin credentials — auto-created in DB on first login attempt
ADMIN_EMAIL=admin@roofscanada.com
ADMIN_PASSWORD=Admin123!

# ── Optional (can be set via Admin → Settings instead) ────────────────────────

# Resend email notifications
# If not set here, configure them in the admin Settings page
RESEND_API_KEY=re_xxxx
SENDER_EMAIL=noreply@yourdomain.com
ADMIN_NOTIFICATION_EMAIL=you@yourdomain.com

# Stripe payments (optional — can be set in admin Settings page)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
